# OpenAI-compatible vision-language model endpoint
PHONE_AGENT_BASE_URL=http://localhost:8000/v1
PHONE_AGENT_MODEL=autoglm-phone-9b
PHONE_AGENT_API_KEY=EMPTY
PHONE_AGENT_DEVICE_ID=

# Runtime limits
PHONE_AGENT_MAX_STEPS=100
PHONE_AGENT_MAX_RUNTIME_SECONDS=900
PHONE_AGENT_MAX_TOKENS=3000
PHONE_AGENT_MAX_FAILURES=3
PHONE_AGENT_MAX_REPEATED_ACTIONS=3
PHONE_AGENT_CONTEXT_TURNS=12
PHONE_AGENT_MODEL_RETRIES=2
PHONE_AGENT_OBSERVATION_RETRIES=2
PHONE_AGENT_TRAJECTORY_DIR=runs

# App discovery and routing
PHONE_AGENT_APP_ALIASES_FILE=
PHONE_AGENT_APP_CATALOG_TTL=300
PHONE_AGENT_APP_PROMPT_LIMIT=5
PHONE_AGENT_MAX_APP_CONTEXT_CHARS=6000

# Verification and recovery
PHONE_AGENT_VERIFICATION_RETRIES=1
PHONE_AGENT_VERIFICATION_THRESHOLD=0.002
PHONE_AGENT_MAX_RECOVERIES=8
PHONE_AGENT_RECOVERY_ATTEMPTS=2

# Model sampling and transport
PHONE_AGENT_TEMPERATURE=0
PHONE_AGENT_TOP_P=0.85
PHONE_AGENT_FREQUENCY_PENALTY=0.2
PHONE_AGENT_MODEL_TIMEOUT=120
PHONE_AGENT_MODEL_RETRY_BACKOFF=1
PHONE_AGENT_CAPTURE_USAGE=1

# Text input timing (seconds)
PHONE_AGENT_KEYBOARD_SWITCH_DELAY=0.5
PHONE_AGENT_TEXT_CLEAR_DELAY=0.35
PHONE_AGENT_TEXT_INPUT_DELAY=0.5
PHONE_AGENT_KEYBOARD_RESTORE_DELAY=0.5

# Device action timing (seconds)
PHONE_AGENT_TAP_DELAY=0.8
PHONE_AGENT_DOUBLE_TAP_DELAY=0.8
PHONE_AGENT_DOUBLE_TAP_INTERVAL=0.12
PHONE_AGENT_LONG_PRESS_DELAY=0.8
PHONE_AGENT_SWIPE_DELAY=0.8
PHONE_AGENT_BACK_DELAY=0.8
PHONE_AGENT_HOME_DELAY=0.8
PHONE_AGENT_LAUNCH_DELAY=1.2
PHONE_AGENT_ADB_RESTART_DELAY=2.0
PHONE_AGENT_SERVER_RESTART_DELAY=1.0
